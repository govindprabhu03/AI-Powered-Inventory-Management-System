# Copy this file to `.env.local` (or `.env`) and fill in the real values.
# Both are gitignored — never commit them. Only this template is committed.
#
# Supabase values: Dashboard → Project Settings → API Keys.

# Safe to expose to the browser. Identifies your project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Safe to expose to the browser. Row Level Security is what protects your data,
# not the secrecy of this key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Absolute URL of this deployment, used to build OAuth and email callback links.
# Local: http://localhost:3000   Production: your Vercel URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SECRET — bypasses Row Level Security entirely. Server-only, never prefixed
# with NEXT_PUBLIC_. Not needed yet; added later for admin tasks.
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
